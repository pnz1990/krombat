# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Required for running tests, the pre-push hook, and terraform locally.
# CI reads AWS_ACCOUNT_ID from the AWS_ACCOUNT_ID GitHub Actions secret.

# Your AWS account ID (12-digit number)
AWS_ACCOUNT_ID=

# Derived values — these are computed automatically from AWS_ACCOUNT_ID.
# You do NOT need to set them unless you want to override.
#
# KUBECTL_CONTEXT=arn:aws:eks:us-west-2:${AWS_ACCOUNT_ID}:cluster/krombat
# AWS_PROFILE=${AWS_ACCOUNT_ID}-Admin
